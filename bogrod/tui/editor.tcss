Screen.editor {
  layout: grid;
  grid-size: 2 2;
  grid-columns: 1fr;
}

Screen.editor > Horizontal {
  layout: grid;
  grid-size: 4 2;
  grid-columns: 1fr 8fr;

}

Screen.editor > TabbedContent > TabPane {
    layout:vertical;
    height: 1fr;
}

OptionList.templates {
  layout: vertical;
  width: 1fr;
}

Markdown {
  margin: 0;
}